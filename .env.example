APP_HOST=0.0.0.0
APP_PORT=8080

# Local-only vLLM URL. Modal sets this automatically inside modal_exact2026.py.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# Option B: one Qwen2.5 base + two loaded LoRA adapters.
BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
TYPE1_MODEL_NAME=type1-logic
TYPE2_MODEL_NAME=type2-physics

TYPE2_FALLBACK_TO_LLM=true
REQUEST_TIMEOUT_SECONDS=50
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=768

# Set true only to test API shape without GPU/vLLM.
MOCK_MODE=false
